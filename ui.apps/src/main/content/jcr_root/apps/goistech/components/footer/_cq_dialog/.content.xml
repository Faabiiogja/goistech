<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    xmlns:granite="http://www.adobe.com/jcr/granite/1.0"
    xmlns:cq="http://www.day.com/jcr/cq/1.0"
    xmlns:jcr="http://www.jcp.org/jcr/1.0"
    xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Footer"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
        <items jcr:primaryType="nt:unstructured">
            <column
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/container">
                <items jcr:primaryType="nt:unstructured">
                    <linkedinUrl
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                        fieldLabel="LinkedIn URL"
                        fieldDescription="Full URL to the Gois Tech LinkedIn profile"
                        emptyText="https://linkedin.com/company/goistech"
                        name="./linkedinUrl"/>
                    <githubUrl
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                        fieldLabel="GitHub URL"
                        fieldDescription="Full URL to the Gois Tech GitHub organization"
                        emptyText="https://github.com/goistech"
                        name="./githubUrl"/>
                    <instagramUrl
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                        fieldLabel="Instagram URL"
                        fieldDescription="Full URL to the Gois Tech Instagram profile"
                        emptyText="https://instagram.com/goistech"
                        name="./instagramUrl"/>
                    <copyrightText
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                        fieldLabel="Copyright Text"
                        fieldDescription="Copyright notice displayed at the bottom of the footer"
                        emptyText="© 2026 Gois Tech. Todos os direitos reservados."
                        name="./copyrightText"/>
                </items>
            </column>
        </items>
    </content>
</jcr:root>
